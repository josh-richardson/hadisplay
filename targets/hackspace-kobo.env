# i.MX6 / hackspace-kobo target.

HADISPLAY_TARGET_NAME="hackspace-kobo"
HADISPLAY_SSH_HOST="hackspace-kobo"
HADISPLAY_DEVICE_LABEL="Kobo Nia / Luna class"
HADISPLAY_EXPECTED_DEVICE_CODE="382"
HADISPLAY_EXPECTED_MODEL="Freescale i.MX6 ULL DDR3 NTX Board"
HADISPLAY_EXPECTED_FRAMEBUFFER="mxc_epdc_fb"
HADISPLAY_EXPECTED_SCREEN="768x1024"
HADISPLAY_REMOTE_DIR="/mnt/onboard/.adds/hadisplay"
HADISPLAY_REMOTE_LOG="/mnt/onboard/.adds/hadisplay/hadisplay.log"
HADISPLAY_APP_DIR="/mnt/onboard/.adds/hadisplay"
HADISPLAY_APP_BIN="hadisplay"
HADISPLAY_APP_LOG="log.txt"
HADISPLAY_LD_LIBRARY_PATH="/mnt/onboard/.niluje/usbnet/lib"
HADISPLAY_NICKEL_BIN="/usr/local/Kobo/nickel"
HADISPLAY_NICKEL_LD_LIBRARY_PATH="/usr/local/Kobo:/lib:/usr/lib"
HADISPLAY_WIFI_INTERFACE="eth0"
HADISPLAY_WIFI_HELPER_DIR="/mnt/onboard/.adds/koreader"
HADISPLAY_DISABLE_WIFI_SCRIPT="/mnt/onboard/.adds/koreader/disable-wifi.sh"
HADISPLAY_ENABLE_WIFI_SCRIPT="/mnt/onboard/.adds/koreader/enable-wifi.sh"
HADISPLAY_OBTAIN_IP_SCRIPT="/mnt/onboard/.adds/koreader/obtain-ip.sh"
HADISPLAY_KEEPALIVE_RELOAD_MODULE="false"
HADISPLAY_KEEPALIVE_MODULE_ROOT="/drivers/${PLATFORM}/wifi"
